// After editing this file, run `npm run db:migrate -- --name <description>` (never `prisma db push`).
// `db push` applies the schema directly without writing a migration file, which silently
// diverges prisma/migrations from the live database and breaks `migrate deploy` on every
// other environment (this has happened repeatedly — see migration history for the scar tissue).
// Run `npm run db:status` any time you're unsure whether the migration history is in sync.

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// CORE ENTITIES
// ============================================================================

/// Club/Organization Configuration
model Club {
  id        String  @id @default(cuid())
  name      String
  shortName String?

  district    String?
  country     String  @default("India")
  logoUrl     String?
  bannerUrl   String?
  tenureYear  String  @default("2026-27")
  foundedYear Int?

  /// Messaging
  presidentMessage String? @db.Text

  /// Logistics
  meetingDay   String?
  meetingTime  String?
  meetingVenue String?

  /// Contact Information
  email      String?
  phone      String?
  website    String?
  address    String?
  city       String?
  state      String?
  postalCode String?

  /// About Information
  description           String?
  missionStatement      String?
  visionStatement       String?
  aboutTitle            String?
  aboutSubtitle         String?
  aboutStory            String? @db.Text
  values                Json?
  history               String? @db.Text
  parentClubName        String?
  parentClubDescription String? @db.Text

  /// Branding
  primaryColor   String @default("#8B5CF6")
  secondaryColor String @default("#EC4899")

  /// Social Media
  socialMedia Json? // { twitter, instagram, facebook, linkedin }

  /// Payment Information
  upiId     String?
  paymentQr String?

  /// Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isActive  Boolean  @default(true)

  // Relations
  members                 Member[]
  boardMembers            BoardMember[]
  projects                Project[]
  events                  Event[]
  announcements           Announcement[]
  albums                  Album[]
  media                   Media[]
  inquiries               MembershipInquiry[]
  sponsors                Sponsor[]
  sponsorshipPackages     SponsorshipPackage[]
  transactions            Transaction[]
  paymentRequests         PaymentRequest[]
  accounts                Account[]
  budgets                 Budget[]
  contributors            Contributor[]
  transfers               Transfer[]
  financialYears          FinancialYear[]
  documents               Document[]
  emailTemplates          EmailTemplate[]
  scheduledCommunications ScheduledCommunication[]
  websiteSettings         WebsiteSettings?
  milestones              Milestone[]
  portfolios              Portfolio[]
  clubRoles               ClubRole[]
  initiatives             Initiative[]
  navigationItems         NavigationItem[]
  websiteMetrics          WebsiteMetric[]
}

// ============================================================================
// WEBSITE CMS
// ============================================================================

model WebsiteSettings {
  id     String @id @default(cuid())
  clubId String @unique
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  // SEO & General Branding
  seoTitle          String?
  seoDescription    String?
  primaryColor      String?  @default("#8B5CF6")
  secondaryColor    String?  @default("#EC4899")
  accentColor       String?  @default("#F4F5F7")
  darkColor         String?  @default("#0B132B")
  lightColor        String?  @default("#FAF9F6")

  // Homepage Settings
  heroHeadline      String?
  heroSubtitle      String?
  heroCTA           String?
  heroCTALink       String?
  heroSecondaryCTA     String?
  heroSecondaryCTALink String?
  heroImages        Json?    // Array of string URLs
  
  // Finance Settings
  upiId             String?

  // President Section
  presName          String?
  presMessage       String?  @db.Text
  presSignature     String?
  presQuote         String?
  presPhoto         String?

  // Homepage Composition & Section Order
  // Stored as JSON: [ { id: "hero", enabled: true, order: 0 }, ... ]
  homepageSections  Json?

  // Gallery Section
  galleryTitle      String?
  gallerySubtitle   String?
  galleryCTA        String?
  galleryCTALink    String?
  galleryLayout     String?  @default("MASONRY") // MASONRY, GRID, CAROUSEL
  galleryShowLatest Boolean  @default(true)
  galleryShowFeatured Boolean @default(false)
  galleryAlbumId    String?
  galleryLimit      Int      @default(3)

  // About Section/Page Content
  aboutEyebrow      String?
  aboutStory        String?  @db.Text
  aboutPhoto        String?
  missionQuote      String?
  visionQuote       String?
  valuesQuote       String?
  noticeboardEyebrow String?
  noticeboardTitle   String?

  // Team Section/Page Content
  teamEyebrow       String?
  teamTitle         String?
  teamSubtitle      String?
  teamLeadershipTitle String?
  teamMembersTitle  String?
  teamJoinCTA       String?
  teamJoinCTALink   String?

  // Projects Section/Page Content
  projectsEyebrow   String?
  projectsTitle     String?
  projectsSubtitle  String?
  projectsActiveTitle String?
  projectsCompletedTitle String?
  projectsEmptyTitle String?
  projectsEmptyDesc String?
  projectsCTA       String?
  projectsCTALink   String?

  // Events Section/Page Content
  eventsEyebrow     String?
  eventsTitle       String?
  eventsSubtitle    String?
  eventsUpcomingTitle String?
  eventsCompletedTitle String?
  eventsEmptyTitle  String?
  eventsEmptyDesc   String?
  eventsRegisterCTA String?
  eventsCompletedCTA String?

  // Footer Config
  footerDescription String?
  footerSocials     Json?    // { twitter, instagram, facebook, linkedin }
  footerQuickLinks  Json?    // Array of { label, url }

  // Sponsors Page Config
  sponsorsTitle      String?
  sponsorsSubtitle   String?
  sponsorsMission    String?
  sponsorsCTA        String?
  sponsorsCTALink    String?
  sponsorsImageUrl   String?

  // Join Page Config
  joinTitle          String?
  joinSubtitle       String?
  joinSuccessTitle   String?
  joinSuccessDesc    String?

  // Archive Page Config
  archiveTitle       String?
  archiveSubtitle    String?

  // Visibilities and statuses for other public pages
  enableJoin         Boolean @default(true)
  enablePartner      Boolean @default(true)
  enableArchive      Boolean @default(true)

  enableEvents           Boolean @default(true)
  enableAnnouncements    Boolean @default(true)
  enablePortfolios       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NavigationItem {
  id           String   @id @default(cuid())
  clubId       String
  club         Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  label        String
  url          String
  displayOrder Int      @default(0)
  visible      Boolean  @default(true)
  external     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model WebsiteMetric {
  id           String   @id @default(cuid())
  clubId       String
  club         Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  number       String
  label        String
  description  String?  @db.Text
  displayOrder Int      @default(0)
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Milestone {
  id     String @id @default(cuid())
  clubId String
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  year         String
  title        String
  description  String? @db.Text
  displayOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================================
// PORTFOLIOS & ROLES
// ============================================================================

model Portfolio {
  id     String @id @default(cuid())
  clubId String
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  name        String
  icon        String? // Lucide icon name or emoji
  description String? @db.Text
  activities  Json? // String[]

  displayOrder Int     @default(0)
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments MemberPortfolioAssignment[]
  initiatives Initiative[]
}

model ClubRole {
  id     String @id @default(cuid())
  clubId String
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  name     String
  category String // "BOARD" | "CORE_TEAM" | "MEMBER"

  displayOrder Int  @default(0)
  maxMembers   Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  boardMembers BoardMember[]
}

model MemberPortfolioAssignment {
  id String @id @default(cuid())

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  portfolioId String
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  roleTitle  String? // e.g., "Chair", "Volunteer"
  tenureYear String // e.g., "2026-27"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([memberId, portfolioId, tenureYear])
}

// ============================================================================
// INITIATIVE PROPOSALS
// ============================================================================

enum InitiativeStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  NEEDS_CHANGES
  APPROVED
  REJECTED
  CONVERTED
}

model Initiative {
  id     String @id @default(cuid())
  clubId String
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  proposedById String
  proposedBy   Member @relation(fields: [proposedById], references: [id], onDelete: Cascade)

  title            String
  description      String    @db.Text
  problemStatement String?   @db.Text
  expectedImpact   String?   @db.Text
  estimatedBudget  Decimal?  @db.Decimal(10, 2)
  preferredDate    DateTime?
  attachments      String[]  @default([])

  portfolioId String?
  portfolio   Portfolio? @relation(fields: [portfolioId], references: [id], onDelete: SetNull)

  status InitiativeStatus @default(DRAFT)

  submittedAt  DateTime?
  reviewedById String?
  reviewedBy   User?     @relation("InitiativeReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments         InitiativeComment[]
  convertedEvent   Event?
  convertedProject Project?

  @@index([clubId])
  @@index([proposedById])
}

model InitiativeComment {
  id           String     @id @default(cuid())
  initiativeId String
  initiative   Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  body   String @db.Text
  action String @default("COMMENT") // COMMENT | REQUESTED_CHANGES | APPROVED | REJECTED

  createdAt DateTime @default(now())

  @@index([initiativeId])
}

// ============================================================================
// NEW ENUMS FOR PROJECTS AND EVENTS
// ============================================================================

enum ProjectCategory {
  COMMUNITY_SERVICE
  PROFESSIONAL_DEVELOPMENT
  CLUB_SERVICE
  INTERNATIONAL_SERVICE
  FUNDRAISER
  OTHER
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  COMPLETED
  ON_HOLD
  CANCELLED
}

enum PublishStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum ProjectRole {
  CHAIR
  CO_CHAIR
  ORGANIZER
  VOLUNTEER
}

enum EventRole {
  CHAIR
  CO_CHAIR
  ORGANIZER
  VOLUNTEER
}

enum Visibility {
  PUBLIC
  INTERNAL
  MEMBERS_ONLY
  BOARD_ONLY
}

enum EventType {
  COMMUNITY_SERVICE
  PROFESSIONAL_DEVELOPMENT
  CLUB_SERVICE
  INTERNATIONAL_SERVICE
  FUNDRAISER
  MEETING
  FELLOWSHIP
}

enum EventStatus {
  DRAFT
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
  PLANNING
}

enum RegistrationStatus {
  REGISTERED
  ATTENDED
  CANCELLED
  WAITLISTED
}

enum InquiryStatus {
  PENDING
  REVIEWING
  CONTACTED
  CONVERTED
  REJECTED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum AttendanceMethod {
  MANUAL
  QR_CODE
  IMPORT
}

enum MediaType {
  IMAGE
  VIDEO_LINK
  DOCUMENT
}

enum MediaUsage {
  COVER
  BANNER
  POSTER
  GALLERY
  ATTACHMENT
  DOCUMENT_REPORT
  DOCUMENT_MINUTES
  WEBSITE
}

// ============================================================================
// PUBLISHING & COMMUNICATIONS
// ============================================================================

enum EmailTemplateType {
  EVENT_PUBLISHED
  EVENT_UPDATED
  EVENT_REMINDER
  PROJECT_PUBLISHED
  ANNOUNCEMENT_PUBLISHED
  ATTENDANCE_CONFIRMED
}

model EmailTemplate {
  id              String            @id @default(cuid())
  clubId          String
  type            EmailTemplateType
  subjectTemplate String
  bodyTemplate    String            @db.Text
  enabled         Boolean           @default(true)

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clubId, type])
}

enum CommunicationStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

model ScheduledCommunication {
  id             String              @id @default(cuid())
  clubId         String
  subject        String
  body           String              @db.Text
  recipientRules Json // { type: "ALL" | "BOARD" | "SPECIFIC", ids?: string[] }
  sendAt         DateTime
  status         CommunicationStatus @default(PENDING)

  eventId        String?
  projectId      String?
  announcementId String?

  errorLog String? @db.Text

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================================
// AUTHENTICATION & USERS
// ============================================================================

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  emailVerified DateTime?
  password      String // Should be hashed
  name          String?
  avatar        String?
  roles         SystemRole[] @default([MEMBER]) // System access roles

  /// Account status
  isActive  Boolean   @default(true)
  lastLogin DateTime?

  /// Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  member       Member?
  sessions     Session[]
  auditLogs    AuditLog[]
  transactions Transaction[]

  markedAttendances  Attendance[]        @relation("AttendanceMarker")
  attendanceSessions AttendanceSession[] @relation("AttendanceSessionCreator")
  uploadedMedia      Media[]             @relation("MediaUploader")

  reviewedInitiatives Initiative[]        @relation("InitiativeReviewer")
  initiativeComments  InitiativeComment[]
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================================
// ROLES & PERMISSIONS
// ============================================================================

enum SystemRole {
  SUPER_ADMIN
  CLUB_ADMIN
  FINANCE_ADMIN
  FINANCE_VIEWER
  EVENTS_ADMIN
  CONTENT_ADMIN
  MEMBER
}

// ============================================================================
// MEMBERS
// ============================================================================

model Member {
  id     String  @id @default(cuid())
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  clubId String
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  name     String? // Decoupled public profile name
  avatar   String? // Decoupled public profile avatar
  email    String? // Contact email for public profile (not a login credential)
  joinedAt DateTime @default(now())

  // Member Profile
  phone            String?
  profession       String?
  companyName      String?
  location         String?
  bio              String?
  websiteQuote     String?  @db.Text
  emergencyContact String?
  skills           String[]
  membershipStatus String   @default("ACTIVE") // ACTIVE, ALUMNI, HONORARY, SUSPENDED

  // Blood Donation (for future)
  bloodGroup   String?
  canDonate    Boolean   @default(false)
  lastDonation DateTime?

  isActive      Boolean  @default(true)
  showOnWebsite Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  boardMemberships     BoardMember[]
  projectRoles         ProjectMember[]
  eventRoles           EventMember[]
  registrations        Registration[]
  attendance           Attendance[]
  transactions         Transaction[]
  paymentRequests      PaymentRequestAssignee[]
  portfolioAssignments MemberPortfolioAssignment[]
  initiatives          Initiative[]
}

model BoardMember {
  id       String @id @default(cuid())
  memberId String @unique
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  clubId String
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  position String // President, Secretary, Treasurer, etc.
  order    Int // Display order

  financialYearId String
  financialYear   FinancialYear @relation(fields: [financialYearId], references: [id], onDelete: Cascade)

  roleId String?
  role   ClubRole? @relation(fields: [roleId], references: [id], onDelete: SetNull)

  joinedAt DateTime  @default(now())
  leftAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clubId, memberId, position, financialYearId])
}

model ProjectMember {
  id        String      @id @default(cuid())
  projectId String
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  memberId  String
  member    Member      @relation(fields: [memberId], references: [id], onDelete: Cascade)
  role      ProjectRole @default(VOLUNTEER)
  joinedAt  DateTime    @default(now())

  @@unique([projectId, memberId])
}

model EventMember {
  id       String    @id @default(cuid())
  eventId  String
  event    Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  memberId String
  member   Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  role     EventRole @default(VOLUNTEER)
  joinedAt DateTime  @default(now())

  @@unique([eventId, memberId])
}

// ============================================================================
// EVENTS
// ============================================================================

model Project {
  id     String @id @default(cuid())
  clubId String
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  title         String
  slug          String          @unique
  description   String          @db.Text
  category      ProjectCategory @default(COMMUNITY_SERVICE)
  status        ProjectStatus   @default(ACTIVE)
  driveFolderId String?
  startDate     DateTime
  endDate       DateTime?
  isFeatured    Boolean         @default(false)
  impactSummary String?         @db.Text
  visibility    Visibility      @default(PUBLIC)
  publishStatus PublishStatus   @default(DRAFT)
  publishAt     DateTime?
  publishedAt   DateTime?
  impactMetrics Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  initiativeId String?     @unique
  initiative   Initiative? @relation(fields: [initiativeId], references: [id], onDelete: SetNull)

  events       Event[]
  members      ProjectMember[]
  albums       Album[]
  media        Media[]
  transactions Transaction[]
  budget       Budget?

  @@unique([clubId, slug])
}

model Event {
  id     String @id @default(cuid())
  clubId String
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  driveFolderId String?

  title       String
  slug        String
  description String?   @db.Text
  type        EventType @default(MEETING)

  location    String?
  meetingLink String?
  latitude    Float?
  longitude   Float?

  startDate DateTime
  startTime DateTime
  endTime   DateTime?

  capacity             Int?
  registrationRequired Boolean @default(false)
  registrationEnabled  Boolean @default(false)
  registeredCount      Int     @default(0)

  // Media
  bannerMediaId String?
  posterMediaId String?

  // Impact
  volunteerHours Int?
  fundsRaised    Float?
  impactMetrics  Json?

  visibility    Visibility    @default(PUBLIC)
  publishStatus PublishStatus @default(DRAFT)
  publishAt     DateTime?
  publishedAt   DateTime?
  isFeatured    Boolean       @default(false)

  status             EventStatus @default(UPCOMING)
  isAttendanceLocked Boolean     @default(false)

  calendarEventId String?

  /// Rich metadata
  tags     String[]
  category String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  initiativeId String?     @unique
  initiative   Initiative? @relation(fields: [initiativeId], references: [id], onDelete: SetNull)

  // Relations
  members            EventMember[]
  registrations      Registration[]
  attendance         Attendance[]
  attendanceSessions AttendanceSession[]
  minutes            EventMinutes?
  albums             Album[]
  media              Media[]
  transactions       Transaction[]
  budget             Budget?

  @@unique([clubId, slug])
}

model Registration {
  id      String @id @default(cuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  registeredAt DateTime           @default(now())
  status       RegistrationStatus @default(REGISTERED)

  createdAt DateTime @default(now())

  @@unique([eventId, memberId])
}

model MembershipInquiry {
  id     String @id @default(cuid())
  clubId String
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  name            String
  email           String
  phone           String?
  interestMessage String?       @db.Text
  status          InquiryStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Attendance {
  id      String @id @default(cuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  checkedInAt DateTime         @default(now())
  method      AttendanceMethod @default(MANUAL)
  status      AttendanceStatus @default(PRESENT)

  volunteerHours Decimal? @db.Decimal(10, 2)

  markedById String?
  markedBy   User?   @relation("AttendanceMarker", fields: [markedById], references: [id], onDelete: SetNull)

  @@unique([eventId, memberId])
}

model AttendanceSession {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  active    Boolean  @default(true)

  createdById String?
  createdBy   User?   @relation("AttendanceSessionCreator", fields: [createdById], references: [id], onDelete: SetNull)

  checkInCodeHash String? // Optional for backward compatibility, stores the hashed 6-digit code
  startsAt        DateTime @default(now())
  createdAt       DateTime @default(now())
}

model EventMinutes {
  id          String    @id @default(cuid())
  eventId     String    @unique
  event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  content     String    @db.Text
  createdBy   String?
  approvedBy  String?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
}

// ============================================================================
// GALLERY & MEDIA
// ============================================================================

model Album {
  id     String @id @default(cuid())
  clubId String
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  title       String
  description String?

  eventId String?
  event   Event?  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  coverMediaId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  media Media[]
}

model Media {
  id     String @id @default(cuid())
  clubId String
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  eventId   String?
  event     Event?   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  albumId String?
  album   Album?  @relation(fields: [albumId], references: [id], onDelete: Cascade)

  driveFileId String?

  url     String
  title   String?
  caption String?
  altText String?

  type  MediaType  @default(IMAGE)
  usage MediaUsage @default(GALLERY)

  displayOrder Int     @default(0)
  isCover      Boolean @default(false)
  isFeatured   Boolean @default(false)

  uploadedById String?
  uploadedBy   User?   @relation("MediaUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================================
// CONTENT MANAGEMENT
// ============================================================================

model Page {
  id     String @id @default(cuid())
  clubId String @unique

  title       String
  slug        String  @unique
  description String?
  content     String? // Markdown content

  seoTitle       String?
  seoDescription String?
  seoKeywords    String?

  isPublished Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================================
// AUDIT & LOGGING
// ============================================================================

model AuditLog {
  id     String  @id @default(cuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  action   String // "create", "update", "delete", etc.
  entity   String // "member", "event", "project", etc.
  entityId String?

  changes   Json? // Track what changed
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// ============================================================================
// CONFIGURATION & SETTINGS
// ============================================================================

model Setting {
  id          String  @id @default(cuid())
  key         String  @unique
  value       String
  type        String // "string", "number", "boolean", "json"
  description String?
  isPublic    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================================
// FINANCE & TREASURY
// ============================================================================

model FinanceCategory {
  id           String          @id @default(cuid())
  name         String
  type         TransactionType
  transactions Transaction[]
}

model Budget {
  id              String         @id @default(cuid())
  clubId          String
  club            Club           @relation(fields: [clubId], references: [id], onDelete: Cascade)
  allocatedAmount Decimal        @db.Decimal(10, 2)
  projectId       String?        @unique
  project         Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  eventId         String?        @unique
  event           Event?         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  financialYearId String?
  financialYear   FinancialYear? @relation(fields: [financialYearId], references: [id], onDelete: SetNull)
  createdAt       DateTime       @default(now())
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  VOIDED
}

enum TransactionCategory {
  DUES
  EVENT_FEE
  DONATION
  SPONSORSHIP
  CATERING
  LOGISTICS
  MARKETING
  OTHER
}

model PaymentRequest {
  id     String @id @default(cuid())
  clubId String
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  title       String
  description String?
  amount      Float
  category    TransactionCategory @default(OTHER)
  isGlobal    Boolean             @default(false)
  dueDate     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dismissedBy String[] @default([])

  assignees    PaymentRequestAssignee[]
  transactions Transaction[]

  @@index([clubId])
}

model PaymentRequestAssignee {
  id               String         @id @default(cuid())
  paymentRequestId String
  paymentRequest   PaymentRequest @relation(fields: [paymentRequestId], references: [id], onDelete: Cascade)

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([paymentRequestId, memberId])
  @@index([memberId])
}

model Transaction {
  id     String @id @default(cuid())
  clubId String
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  title       String
  description String?
  amount      Decimal           @db.Decimal(10, 2)
  type        TransactionType
  status      TransactionStatus @default(PENDING_APPROVAL)

  date DateTime @default(now())

  categoryId String?
  category   FinanceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  eventId String?
  event   Event?  @relation(fields: [eventId], references: [id], onDelete: SetNull)

  receiptUrl String?

  createdBy  String?
  approvedBy String?
  approvedAt DateTime?

  paymentMethod   String? // CASH, UPI, BANK_TRANSFER, OTHER
  referenceNumber String?

  accountId String?
  account   Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  financialYearId String?
  financialYear   FinancialYear? @relation(fields: [financialYearId], references: [id], onDelete: SetNull)

  contributorId String?
  contributor   Contributor? @relation(fields: [contributorId], references: [id], onDelete: SetNull)

  /// Association with members or users
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  memberId String?
  member   Member? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  /// Association with Payment Request
  paymentRequestId String?
  paymentRequest   PaymentRequest? @relation(fields: [paymentRequestId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clubId])
  @@index([memberId])
  @@index([eventId])
  @@index([projectId])
  @@index([paymentRequestId])
}

// ============================================================================
// MEETINGS
// ============================================================================

enum AnnouncementType {
  GENERAL
  BOARD_MEETING
  CLUB_MEETING
  EVENT_UPDATE
  FINANCE_NOTICE
  IMPORTANT_NOTICE
}

enum AnnouncementStatus {
  DRAFT
  PUBLISHED
  CANCELLED
}

model Announcement {
  id          String  @id @default(cuid())
  clubId      String
  club        Club    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  title       String
  description String? // Raw text or summary

  publishStatus PublishStatus @default(DRAFT)
  publishAt     DateTime?
  publishedAt   DateTime?
  startDate     DateTime?
  endDate       DateTime?
  location      String?
  meetingLink   String?

  // Content fields
  emailSubject   String?
  emailBody      String? // Rich Text
  agendaContent  String? // Rich Text
  minutesContent String? // Rich Text

  // Attachments (Storage URLs)
  agendaUrl   String?
  minutesUrl  String?
  attachments String[] // List of URLs

  // Integrations & Status
  calendarEventId String?
  type            AnnouncementType   @default(GENERAL)
  status          AnnouncementStatus @default(DRAFT)
  visibility      Visibility         @default(PUBLIC)

  // Delivery Tracking
  sendInvite      Boolean   @default(false)
  sentAt          DateTime?
  deliveryStatus  String?
  recipientsCount Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Sponsor {
  id     String @id @default(cuid())
  clubId String
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  name        String
  logo        String?
  website     String?
  description String? @db.Text
  year        String? // e.g. "2026-27"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================================
// COMMUNICATIONS & NOTIFICATIONS
// ============================================================================

enum NotificationTrigger {
  EVENT_CREATED
  EVENT_UPDATED
  EVENT_REMINDER
  MEETING_CREATED
  MINUTES_PUBLISHED
  ATTENDANCE_CONFIRMED
}

model CommunicationLog {
  id              String              @id @default(cuid())
  trigger         NotificationTrigger
  subject         String
  body            String              @db.Text
  recipientsCount Int                 @default(0)
  status          String // SUCCESS, FAILED
  error           String?             @db.Text

  // Optional references back to what triggered it
  eventId        String?
  announcementId String?

  createdAt DateTime @default(now())
}

// ============================================================================
// DOCUMENT MANAGEMENT (Supabase Storage Integrations)
// ============================================================================

enum DocumentType {
  EVENT_IMAGE
  PROJECT_IMAGE
  AGENDA
  MINUTES
  FINANCE_RECEIPT
  REPORT
  CERTIFICATE
  CLUB_ASSET
}

model Document {
  id          String       @id @default(cuid())
  fileName    String
  fileUrl     String
  displayName String
  type        DocumentType

  uploadedBy String? // Reference to userId

  linkedEntityType String? // e.g. "EVENT", "PROJECT", "FINANCE"
  linkedEntityId   String? // ID of the linked entity

  clubId String?
  club   Club?   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model FinancialYear {
  id             String        @id @default(cuid())
  clubId         String
  club           Club          @relation(fields: [clubId], references: [id], onDelete: Cascade)
  name           String        @unique // e.g. "RY 2026-27"
  startDate      DateTime
  endDate        DateTime
  openingBalance Decimal       @db.Decimal(10, 2)
  closingBalance Decimal?      @db.Decimal(10, 2)
  status         String        @default("ACTIVE") // ACTIVE, CLOSED
  transactions   Transaction[]
  budgets        Budget[]
  transfers      Transfer[]
  boardMembers   BoardMember[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Account {
  id             String        @id @default(cuid())
  clubId         String
  club           Club          @relation(fields: [clubId], references: [id], onDelete: Cascade)
  name           String // Cash, Bank Account, UPI Wallet
  type           String // CASH, BANK, UPI, OTHER
  currentBalance Decimal       @default(0) @db.Decimal(10, 2)
  transactions   Transaction[]
  transfersFrom  Transfer[]    @relation("TransfersFrom")
  transfersTo    Transfer[]    @relation("TransfersTo")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Transfer {
  id              String         @id @default(cuid())
  clubId          String
  club            Club           @relation(fields: [clubId], references: [id], onDelete: Cascade)
  fromAccountId   String
  fromAccount     Account        @relation("TransfersFrom", fields: [fromAccountId], references: [id], onDelete: Cascade)
  toAccountId     String
  toAccount       Account        @relation("TransfersTo", fields: [toAccountId], references: [id], onDelete: Cascade)
  amount          Decimal        @db.Decimal(10, 2)
  date            DateTime       @default(now())
  financialYearId String?
  financialYear   FinancialYear? @relation(fields: [financialYearId], references: [id], onDelete: SetNull)
  createdBy       String?
  createdAt       DateTime       @default(now())
}

model Contributor {
  id               String        @id @default(cuid())
  clubId           String
  club             Club          @relation(fields: [clubId], references: [id], onDelete: Cascade)
  name             String
  contact          String?
  type             String // SPONSOR, DONOR, PARTNER
  totalContributed Decimal       @default(0) @db.Decimal(10, 2)
  transactions     Transaction[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model SponsorshipPackage {
  id           String   @id @default(cuid())
  clubId       String
  club         Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  title        String
  amount       Int
  impactText   String
  description  String?  @db.Text
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

