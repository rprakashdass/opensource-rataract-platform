generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// CORE ENTITIES
// ============================================================================

/// Club/Organization Configuration
model Club {
  id         String  @id @default(cuid())
  name       String
  district   String?
  country    String  @default("India")
  logoUrl    String?
  bannerUrl  String?
  tenureYear String  @default("2026-27")

  /// Contact Information
  email      String?
  phone      String?
  website    String?
  address    String?
  city       String?
  state      String?
  postalCode String?

  /// About Information
  description      String?
  missionStatement String?
  visionStatement  String?

  /// Branding
  primaryColor   String @default("#8B5CF6")
  secondaryColor String @default("#EC4899")

  /// Social Media
  socialMedia Json? // { twitter, instagram, facebook, linkedin }

  /// Payment Information
  upiId     String?
  paymentQr String?

  /// Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isActive  Boolean  @default(true)

  // Relations
  members         Member[]
  boardMembers    BoardMember[]
  projects        Project[]
  events          Event[]
  announcements   Announcement[]
  media           Media[]
  transactions    Transaction[]
  paymentRequests PaymentRequest[]
  accounts        Account[]
  budgets         Budget[]
  contributors    Contributor[]
  transfers       Transfer[]
  financialYears  FinancialYear[]
}

// ============================================================================
// NEW ENUMS FOR PROJECTS AND EVENTS
// ============================================================================

enum ProjectCategory {
  COMMUNITY_SERVICE
  PROFESSIONAL_DEVELOPMENT
  CLUB_SERVICE
  INTERNATIONAL_SERVICE
  FUNDRAISER
  OTHER
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  COMPLETED
  ON_HOLD
  CANCELLED
}

enum Visibility {
  PUBLIC
  MEMBERS_ONLY
  BOARD_ONLY
}

enum EventType {
  COMMUNITY_SERVICE
  PROFESSIONAL_DEVELOPMENT
  CLUB_SERVICE
  INTERNATIONAL_SERVICE
  FUNDRAISER
  MEETING
  FELLOWSHIP
}

enum EventStatus {
  DRAFT
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum RegistrationStatus {
  REGISTERED
  ATTENDED
  CANCELLED
  WAITLISTED
}

enum AttendanceMethod {
  MANUAL
  QR_CODE
  IMPORT
}

// ============================================================================
// AUTHENTICATION & USERS
// ============================================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  password      String // Should be hashed
  name          String?
  avatar        String?
  roles         Role[]    @default([MEMBER]) // System access roles

  /// Account status
  isActive  Boolean   @default(true)
  lastLogin DateTime?

  /// Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  member       Member?
  sessions     Session[]
  auditLogs    AuditLog[]
  transactions Transaction[]
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================================
// ROLES & PERMISSIONS
// ============================================================================

enum Role {
  ADMIN
  CLUB_ADMIN
  PRESIDENT
  SECRETARY
  TREASURER
  BOARD_MEMBER
  MEMBER
  GUEST
  FINANCE_ADMIN
  FINANCE_VIEWER
}

model Permission {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  resource    String // e.g., "events", "members", "projects"
  action      String // e.g., "create", "read", "update", "delete"

  createdAt DateTime @default(now())

  // Relations
  rolePermissions RolePermission[]
}

model RolePermission {
  id          String       @id @default(cuid())
  role        Role         @unique
  permissions Permission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================================
// MEMBERS
// ============================================================================

model Member {
  id     String  @id @default(cuid())
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  clubId String
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  name     String? // Decoupled public profile name
  avatar   String? // Decoupled public profile avatar
  email    String? // Contact email for public profile (not a login credential)
  joinedAt DateTime @default(now())

  // Member Profile
  phone       String?
  profession  String?
  companyName String?
  location    String?
  bio         String?

  // Blood Donation (for future)
  bloodGroup   String?
  canDonate    Boolean   @default(false)
  lastDonation DateTime?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  boardMembership BoardMember?
  registrations   Registration[]
  attendance      Attendance[]
  transactions    Transaction[]
  paymentRequests PaymentRequestAssignee[]
}

model BoardMember {
  id       String @id @default(cuid())
  memberId String @unique
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  clubId String
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  position String // President, Secretary, Treasurer, etc.
  order    Int // Display order

  joinedAt DateTime  @default(now())
  leftAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clubId, memberId])
}

// ============================================================================
// EVENTS
// ============================================================================

model Project {
  id     String @id @default(cuid())
  clubId String
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  title         String
  slug          String          @unique
  description   String          @db.Text
  category      ProjectCategory @default(COMMUNITY_SERVICE)
  status        ProjectStatus   @default(ACTIVE)
  startDate     DateTime
  endDate       DateTime?
  coverImage    String?
  chairPersonId String?
  visibility    Visibility      @default(PUBLIC)
  impactMetrics Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events       Event[]
  media        Media[]
  transactions Transaction[]
  budget       Budget?

  @@unique([clubId, slug])
}

model Event {
  id     String @id @default(cuid())
  clubId String
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  title       String
  slug        String
  description String?   @db.Text
  type        EventType @default(MEETING)

  location  String?
  latitude  Float?
  longitude Float?

  startDate DateTime // Keeping startDate instead of startTime for backward compat with some UI parts, or change to startTime? User requested startTime and endTime, but let's stick to startDate/endDate for less UI breakage if possible. Wait, let's use what user asked: startTime and endTime.
  startTime DateTime
  endTime   DateTime?

  imageUrl     String?
  thumbnailUrl String?

  capacity             Int?
  registrationRequired Boolean @default(false)
  registeredCount      Int     @default(0)

  status EventStatus @default(UPCOMING)

  calendarEventId String?

  /// Rich metadata
  tags     String[]
  category String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  registrations Registration[]
  attendance    Attendance[]
  minutes       EventMinutes?
  media         Media[]
  transactions  Transaction[]
  budget        Budget?

  @@unique([clubId, slug])
}

model Registration {
  id      String @id @default(cuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  registeredAt DateTime           @default(now())
  status       RegistrationStatus @default(REGISTERED)

  createdAt DateTime @default(now())

  @@unique([eventId, memberId])
}

model Attendance {
  id      String @id @default(cuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  checkedInAt DateTime         @default(now())
  method      AttendanceMethod @default(MANUAL)

  @@unique([eventId, memberId])
}

model EventMinutes {
  id          String    @id @default(cuid())
  eventId     String    @unique
  event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  content     String    @db.Text
  createdBy   String?
  approvedBy  String?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
}

// ============================================================================
// GALLERY
// ============================================================================

model Media {
  id     String @id @default(cuid())
  clubId String
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  eventId   String?
  event     Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  url        String
  caption    String?
  uploadedBy String?
  createdAt  DateTime @default(now())
}

// ============================================================================
// CONTENT MANAGEMENT
// ============================================================================

model Page {
  id     String @id @default(cuid())
  clubId String @unique

  title       String
  slug        String  @unique
  description String?
  content     String? // Markdown content

  seoTitle       String?
  seoDescription String?
  seoKeywords    String?

  isPublished Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================================
// AUDIT & LOGGING
// ============================================================================

model AuditLog {
  id     String  @id @default(cuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  action   String // "create", "update", "delete", etc.
  entity   String // "member", "event", "project", etc.
  entityId String?

  changes   Json? // Track what changed
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// ============================================================================
// CONFIGURATION & SETTINGS
// ============================================================================

model Setting {
  id          String  @id @default(cuid())
  key         String  @unique
  value       String
  type        String // "string", "number", "boolean", "json"
  description String?
  isPublic    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================================
// FINANCE & TREASURY
// ============================================================================

model FinanceCategory {
  id           String          @id @default(cuid())
  name         String
  type         TransactionType
  transactions Transaction[]
}

model Budget {
  id              String         @id @default(cuid())
  clubId          String
  club            Club           @relation(fields: [clubId], references: [id], onDelete: Cascade)
  allocatedAmount Decimal        @db.Decimal(10, 2)
  projectId       String?        @unique
  project         Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  eventId         String?        @unique
  event           Event?         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  financialYearId String?
  financialYear   FinancialYear? @relation(fields: [financialYearId], references: [id], onDelete: SetNull)
  createdAt       DateTime       @default(now())
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  VOIDED
}

enum TransactionCategory {
  DUES
  EVENT_FEE
  DONATION
  SPONSORSHIP
  CATERING
  LOGISTICS
  MARKETING
  OTHER
}

model PaymentRequest {
  id     String @id @default(cuid())
  clubId String
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  title       String
  description String?
  amount      Float
  category    TransactionCategory @default(OTHER)
  isGlobal    Boolean             @default(false)
  dueDate     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dismissedBy String[] @default([])

  assignees    PaymentRequestAssignee[]
  transactions Transaction[]

  @@index([clubId])
}

model PaymentRequestAssignee {
  id               String         @id @default(cuid())
  paymentRequestId String
  paymentRequest   PaymentRequest @relation(fields: [paymentRequestId], references: [id], onDelete: Cascade)

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([paymentRequestId, memberId])
  @@index([memberId])
}

model Transaction {
  id     String @id @default(cuid())
  clubId String
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  title       String
  description String?
  amount      Decimal           @db.Decimal(10, 2)
  type        TransactionType
  status      TransactionStatus @default(PENDING_APPROVAL)

  date DateTime @default(now())

  categoryId String?
  category   FinanceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  eventId String?
  event   Event?  @relation(fields: [eventId], references: [id], onDelete: SetNull)

  receiptUrl String?

  createdBy  String?
  approvedBy String?
  approvedAt DateTime?

  paymentMethod   String? // CASH, UPI, BANK_TRANSFER, OTHER
  referenceNumber String?

  accountId String?
  account   Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  financialYearId String?
  financialYear   FinancialYear? @relation(fields: [financialYearId], references: [id], onDelete: SetNull)

  contributorId String?
  contributor   Contributor? @relation(fields: [contributorId], references: [id], onDelete: SetNull)

  /// Association with members or users
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  memberId String?
  member   Member? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  /// Association with Payment Request
  paymentRequestId String?
  paymentRequest   PaymentRequest? @relation(fields: [paymentRequestId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clubId])
  @@index([memberId])
  @@index([eventId])
  @@index([projectId])
  @@index([paymentRequestId])
}

// ============================================================================
// MEETINGS
// ============================================================================

enum AnnouncementType {
  MEETING
  GATHERING
  DISCUSSION
  OTHER
}

model Announcement {
  id              String           @id @default(cuid())
  clubId          String
  club            Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  startDate       DateTime
  endDate         DateTime?
  location        String?
  meetingLink     String?
  agendaUrl       String?
  minutesUrl      String?
  calendarEventId String?
  type            AnnouncementType @default(MEETING)
  sendInvite      Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // attendees AnnouncementAttendance[] removed as part of schema refactor
}

model FinancialYear {
  id             String        @id @default(cuid())
  clubId         String
  club           Club          @relation(fields: [clubId], references: [id], onDelete: Cascade)
  name           String        @unique // e.g. "RY 2026-27"
  startDate      DateTime
  endDate        DateTime
  openingBalance Decimal       @db.Decimal(10, 2)
  closingBalance Decimal?      @db.Decimal(10, 2)
  status         String        @default("ACTIVE") // ACTIVE, CLOSED
  transactions   Transaction[]
  budgets        Budget[]
  transfers      Transfer[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Account {
  id             String        @id @default(cuid())
  clubId         String
  club           Club          @relation(fields: [clubId], references: [id], onDelete: Cascade)
  name           String // Cash, Bank Account, UPI Wallet
  type           String // CASH, BANK, UPI, OTHER
  currentBalance Decimal       @default(0) @db.Decimal(10, 2)
  transactions   Transaction[]
  transfersFrom  Transfer[]    @relation("TransfersFrom")
  transfersTo    Transfer[]    @relation("TransfersTo")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Transfer {
  id              String         @id @default(cuid())
  clubId          String
  club            Club           @relation(fields: [clubId], references: [id], onDelete: Cascade)
  fromAccountId   String
  fromAccount     Account        @relation("TransfersFrom", fields: [fromAccountId], references: [id], onDelete: Cascade)
  toAccountId     String
  toAccount       Account        @relation("TransfersTo", fields: [toAccountId], references: [id], onDelete: Cascade)
  amount          Decimal        @db.Decimal(10, 2)
  date            DateTime       @default(now())
  financialYearId String?
  financialYear   FinancialYear? @relation(fields: [financialYearId], references: [id], onDelete: SetNull)
  createdBy       String?
  createdAt       DateTime       @default(now())
}

model Contributor {
  id               String        @id @default(cuid())
  clubId           String
  club             Club          @relation(fields: [clubId], references: [id], onDelete: Cascade)
  name             String
  contact          String?
  type             String // SPONSOR, DONOR, PARTNER
  totalContributed Decimal       @default(0) @db.Decimal(10, 2)
  transactions     Transaction[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}
